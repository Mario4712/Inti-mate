# ─── Ambiente ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Banco de dados ─────────────────────────────────────────
POSTGRES_USER=intimare
POSTGRES_PASSWORD=secret
POSTGRES_DB=intimare_dev
# Connection pooling: connection_limit (default 10), pool_timeout in seconds
DATABASE_URL="postgresql://intimare:secret@localhost:5432/intimare_dev?schema=public&connection_limit=20&pool_timeout=10"

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=secret
REDIS_URL="redis://:secret@localhost:6379"

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=4d4091bdca546c038b22c02633e7160d6be77227c52401c59a59894e9c6da92c
JWT_REFRESH_SECRET=be3db03e9c6faabf0e66b1135dfeed0a2e091b3ac0f8c84a50b2a2d3c9291303
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (MinIO / S3) ────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_MEDIA=media
S3_BUCKET_KYC=kyc-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
CDN_BASE_URL=http://localhost:9000/media

# ─── E-mail ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Inti.mate <noreply@inti.mate>"

# ─── Moderação / CSAM ────────────────────────────────────────
# PhotoDNA ou hash-matching local
CSAM_PROVIDER=local   # local | photodna
PHOTODNA_API_KEY=

# ─── Verificação de identidade ──────────────────────────────
KYC_PROVIDER=mock     # mock | unico | serpro
UNICO_CLIENT_ID=
UNICO_CLIENT_SECRET=

# ─── Pagamentos ─────────────────────────────────────────────
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRYPTO_WEBHOOK_SECRET=

# ─── 2FA ────────────────────────────────────────────────────
TOTP_APP_NAME=Inti.mate

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Mobile ────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001

# ─── Criptografia CPF (separar do JWT) ─────────────────────
CPF_ENCRYPTION_KEY=cffd0aa9cb4f41a348bcb8202aa77049

# ─── Elasticsearch ──────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=

# ─── LiveKit (lives em tempo real) ──────────────────────────
LIVEKIT_HOST=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ─── Anthropic (IA persona) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Web Push (VAPID) ──────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── NCMEC CyberTipline (reporte CSAM) ─────────────────────
NCMEC_USERNAME=
NCMEC_PASSWORD=
NCMEC_ENDPOINT=https://report.cybertipline.org/ispws/submit

# ─── SaferNet Brasil ────────────────────────────────────────
SAFERNET_ENDPOINT=

# ─── Social Scheduler (APIs de redes sociais) ──────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
TWITTER_BEARER_TOKEN=
TIKTOK_ACCESS_TOKEN=

# ─── Suporte ───────────────────────────────────────────────
SUPPORT_EMAIL=suporte@inti.mate

# ─── OAuth2 (login social) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Sentry (monitoramento) ────────────────────────────────
SENTRY_DSN=

# ─── Docker Registry ───────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/mario4712/inti-mate
