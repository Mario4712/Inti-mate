# ─── Ambiente ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Banco de dados ─────────────────────────────────────────
POSTGRES_USER=intimare
POSTGRES_PASSWORD=secret
POSTGRES_DB=intimare_dev
DATABASE_URL="postgresql://intimare:secret@localhost:5432/intimare_dev?schema=public"

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=secret
REDIS_URL="redis://:secret@localhost:6379"

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=troque_por_segredo_forte_de_64_chars_minimo
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte_de_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (MinIO / S3) ────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_MEDIA=media
S3_BUCKET_KYC=kyc-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
CDN_BASE_URL=http://localhost:9000/media

# ─── E-mail ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Inti.mate <noreply@inti.mate>"

# ─── Moderação / CSAM ────────────────────────────────────────
# PhotoDNA ou hash-matching local
CSAM_PROVIDER=local   # local | photodna
PHOTODNA_API_KEY=

# ─── Verificação de identidade ──────────────────────────────
KYC_PROVIDER=mock     # mock | unico | serpro
UNICO_CLIENT_ID=
UNICO_CLIENT_SECRET=

# ─── Pagamentos ─────────────────────────────────────────────
PAGARME_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── 2FA ────────────────────────────────────────────────────
TOTP_APP_NAME=Inti.mate

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Mobile ────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001

# ─── Criptografia CPF (separar do JWT) ─────────────────────
CPF_ENCRYPTION_KEY=troque_por_chave_aes256_dedicada_32bytes

# ─── Elasticsearch ──────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
