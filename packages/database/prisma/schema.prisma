generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  CONSUMER
  CREATOR
  MODERATOR
  ADMIN
}

enum UserStatus {
  PENDING_EMAIL       // aguardando confirmação de e-mail
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_REVIEW
}

enum VerificationType {
  DECLARATION   // consumidor: checkbox + CPF formato
  DOCUMENT      // criador: doc + selfie completa
}

enum ContentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum ModerationAction {
  APPROVED
  REJECTED
  ESCALATED
  CSAM_REPORTED
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  AGE_VERIFICATION
  CONTENT_CREATION
  DATA_PROCESSING
}

// ─── MONETIZAÇÃO ─────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE      // cobrança falhou, grace period de 3 dias
  CANCELLED
  EXPIRED
}

enum SubscriptionInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TransactionType {
  SUBSCRIPTION
  PPV
  TIP
  SUPERCHAT
  DIGITAL_ITEM
  WITHDRAWAL
  REFUND
}

enum LiveStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum AuctionStatus {
  DRAFT
  OPEN
  CLOSED
  PAID
  CANCELLED
}

enum ToySessionStatus {
  ACTIVE
  ENDED
}

enum TransactionStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  CHARGEBACK
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────
// USUÁRIOS E AUTENTICAÇÃO
// ─────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  username         String     @unique  // handle público (ex: @joaosilva)
  passwordHash     String
  role             Role       @default(CONSUMER)
  status           UserStatus @default(PENDING_EMAIL)
  emailVerified    Boolean    @default(false)
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?    // criptografado em repouso

  // CPF armazenado criptografado — nunca em plaintext
  cpfHash          String?    @unique  // hash para deduplicação
  cpfEncrypted     String?             // encrypted para consulta interna

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?  // soft delete (direito LGPD)

  // Relações
  profile          UserProfile?
  ageVerification  AgeVerification?
  sessions         Session[]
  emailTokens      EmailVerificationToken[]
  consentRecords   ConsentRecord[]
  deletionRequest  DataDeletionRequest?
  creatorPlans       CreatorPlan[]
  subscriptions      Subscription[]      @relation("CreatorSubscriptions")
  mySubscriptions    Subscription[]      @relation("SubscriberSubscriptions")
  media              Media[]
  cryptoTransactions CryptoTransaction[]
  location           UserLocation?
  aiAvatar           AiAvatar?
  contentGenJobs     ContentGenJob[]
  fanEditSuggestions EditSuggestion[]    @relation("FanEditSuggestions")
  liveSessions            LiveSession[]    @relation("CreatorLives")
  creatorConversations    Conversation[]   @relation("CreatorConversations")
  fanConversations        Conversation[]   @relation("FanConversations")

  @@index([email])
  @@index([username])
  @@index([cpfHash])
}

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dados públicos (pseudônimo)
  artisticName String?  @unique  // nome artístico público
  displayName  String?           // nome de exibição (pode ser igual ao artístico)
  bio          String?
  avatarUrl    String?
  coverUrl     String?

  // Dados de localização — apenas cidade/estado, nunca coords
  city         String?
  state        String?
  country      String?  @default("BR")
  showLocation Boolean  @default(false)  // opt-in para exibição

  // Descoberta / SEO
  tags         Json?    @default("[]")   // string[]
  category     String?                  // ex: "fitness", "arte"

  isPublic     Boolean  @default(true)
  isCreator    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([artisticName])
  @@index([category])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  revokedAt    DateTime?

  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  type      String   // "email_verify" | "password_reset"
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// VERIFICAÇÃO DE IDADE / KYC
// ─────────────────────────────────────────────────────────────

model AgeVerification {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  type             VerificationType
  status           VerificationStatus @default(PENDING)

  // Consumidor: apenas declaração
  declarationAt    DateTime?

  // Criador: documento + selfie (URLs do bucket KYC — acesso restrito)
  documentType     String?   // RG | CNH | PASSAPORTE
  documentUrl      String?   // URL S3 criptografada
  selfieUrl        String?   // URL S3 criptografada
  kycProvider      String?   // "unico" | "serpro" | "manual"
  kycExternalId    String?   // ID retornado pelo provedor

  verifiedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  reviewedBy       String?   // userId do moderador

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────
// LGPD — CONSENTIMENTO E EXCLUSÃO DE DADOS
// ─────────────────────────────────────────────────────────────

model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        ConsentType
  version     String      // versão do documento aceito (ex: "tos-v1.2")
  accepted    Boolean
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime    @default(now())

  @@index([userId, type])
}

model DataDeletionRequest {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  requestedAt DateTime @default(now())
  scheduledAt DateTime // execução agendada (ex: 30 dias após solicitação)
  executedAt  DateTime?
  status      String   @default("PENDING")  // PENDING | PROCESSING | COMPLETED
  notes       String?
}

// ─────────────────────────────────────────────────────────────
// MODERAÇÃO DE CONTEÚDO
// ─────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────
// MONETIZAÇÃO — PLANOS, ASSINATURAS, PPV, SAQUES
// ─────────────────────────────────────────────────────────────

model CreatorPlan {
  id             String               @id @default(cuid())
  creatorId      String
  creator        User                 @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  name           String               // "Básico", "VIP", etc.
  description    String?
  monthlyPrice   Decimal              @db.Decimal(10, 2)
  priceQuarterly Decimal?             @db.Decimal(10, 2)
  priceYearly    Decimal?             @db.Decimal(10, 2)
  maxSlots       Int?                 // null = ilimitado
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  subscriptions  Subscription[]

  @@index([creatorId])
}

model Subscription {
  id              String               @id @default(cuid())
  subscriberId    String               // userId do fã
  subscriber      User                 @relation("SubscriberSubscriptions", fields: [subscriberId], references: [id])
  creatorId       String               // userId do criador
  creator         User                 @relation("CreatorSubscriptions",    fields: [creatorId],    references: [id])
  planId          String
  plan            CreatorPlan          @relation(fields: [planId], references: [id])
  status          SubscriptionStatus   @default(ACTIVE)
  interval        SubscriptionInterval @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt     DateTime?
  cancellationReason String?
  gatewaySubscriptionId String?        // ID no Pagar.me ou Stripe
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([subscriberId, creatorId, planId])
  @@index([subscriberId])
  @@index([creatorId])
}

model PpvContent {
  id            String    @id @default(cuid())
  creatorId     String
  title         String
  description   String?
  price         Int       // centavos
  contentUrl    String?   // preenchido após moderação aprovada
  previewUrl    String?   // teaser gratuito
  status        String    @default("PENDING_REVIEW") // ContentStatus
  purchaseCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  purchases     PpvPurchase[]

  @@index([creatorId])
}

model PpvPurchase {
  id          String     @id @default(cuid())
  buyerId     String
  contentId   String
  content     PpvContent @relation(fields: [contentId], references: [id])
  pricePaid   Int        // centavos
  transaction Transaction?
  createdAt   DateTime   @default(now())

  @@unique([buyerId, contentId])
  @@index([buyerId])
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String            // quem pagou
  creatorId        String?           // quem recebeu (null = plataforma)
  type             TransactionType
  status           TransactionStatus @default(PENDING)
  grossAmount      Int               // valor bruto em centavos
  platformFee      Int               // taxa da plataforma em centavos
  netAmount        Int               // valor líquido ao criador
  currency         String            @default("BRL")
  description      String?

  // Referências polimórficas
  subscriptionId   String?
  ppvPurchaseId    String?           @unique
  ppvPurchase      PpvPurchase?      @relation(fields: [ppvPurchaseId], references: [id])
  withdrawalId     String?

  // Gateway
  gatewayProvider  String?           // "pagarme" | "stripe"
  gatewayTxId      String?           @unique
  gatewayPayload   Json?             // resposta raw do gateway

  failureReason    String?
  refundedAt       DateTime?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId])
  @@index([creatorId])
  @@index([gatewayTxId])
}

model CreatorBalance {
  id              String   @id @default(cuid())
  creatorId       String   @unique
  availableAmount Int      @default(0)  // centavos disponíveis para saque
  pendingAmount   Int      @default(0)  // centavos em processamento
  totalEarned     Int      @default(0)  // total histórico
  updatedAt       DateTime @updatedAt
}

model Withdrawal {
  id              String           @id @default(cuid())
  creatorId       String
  amount          Int              // centavos
  status          WithdrawalStatus @default(PENDING)
  pixKey          String           // chave PIX (mascarada nos logs)
  pixKeyType      String           // CPF | EMAIL | PHONE | EVP
  scheduledDate   DateTime         // D+14 da solicitação
  processedAt     DateTime?
  failureReason   String?
  gatewayTxId     String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([creatorId])
}

// ─────────────────────────────────────────────────────────────
// MODERAÇÃO DE CONTEÚDO
// ─────────────────────────────────────────────────────────────

model ModerationLog {
  id            String           @id @default(cuid())
  contentId     String           // ID do conteúdo moderado
  contentType   String           // "photo" | "video" | "message" | "profile"

  action        ModerationAction
  moderatorId   String?          // null = automático (IA/CSAM scan)
  reason        String?

  csamHash      String?          // hash do arquivo para registro
  reportedToAuthority Boolean    @default(false)
  reportReference     String?    // protocolo de reporte ao MP/NCMEC

  createdAt     DateTime         @default(now())

  @@index([contentId, contentType])
}

// ─────────────────────────────────────────────────────────────
// CONTEÚDO — GALERIA, STORIES
// ─────────────────────────────────────────────────────────────

enum MediaType {
  PHOTO
  VIDEO
}

enum MediaVisibility {
  PUBLIC       // visível sem assinatura
  SUBSCRIBERS  // apenas assinantes
  PPV          // vinculado a PpvContent
}

model Media {
  id            String          @id @default(cuid())
  creatorId     String
  creator       User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  type          MediaType
  visibility    MediaVisibility @default(SUBSCRIBERS)
  title         String?
  description   String?

  // URLs resolvidas após processamento
  originalUrl   String?         // arquivo original no S3
  processedUrl  String?         // versão otimizada / HLS manifest (.m3u8)
  thumbnailUrl  String?
  previewUrl    String?         // teaser público (sem moderação de conteúdo adulto)

  // Metadados técnicos
  durationSec   Int?            // vídeos
  fileSizeBytes BigInt?
  mimeType      String?
  width         Int?
  height        Int?

  status        String          @default("PENDING_REVIEW")  // ContentStatus
  viewCount     Int             @default(0)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  editSuggestions EditSuggestion[]
  vrContent       VrContent?
  accessLogs      MediaAccessLog[]
  custodyReviews  ContentCustodyReview[]

  @@index([creatorId, status])
  @@index([creatorId, visibility])
}

model Story {
  id          String   @id @default(cuid())
  creatorId   String
  mediaUrl    String
  mediaType   MediaType
  expiresAt   DateTime          // 24h após criação
  viewCount   Int      @default(0)
  status      String   @default("PENDING_REVIEW")
  createdAt   DateTime @default(now())

  views       StoryView[]

  @@index([creatorId])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId  String
  viewedAt  DateTime @default(now())

  @@unique([storyId, viewerId])
}

// ─────────────────────────────────────────────────────────────
// MENSAGENS PRIVADAS
// ─────────────────────────────────────────────────────────────

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FLAGGED
  DELETED
}

model Conversation {
  id           String    @id @default(cuid())
  creatorId    String
  fanId        String
  isPaid       Boolean   @default(false)
  pricePerMsg  Int?      // centavos; null = grátis
  isBlocked    Boolean   @default(false)
  blockedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  creator      User      @relation("CreatorConversations", fields: [creatorId], references: [id])
  fan          User      @relation("FanConversations", fields: [fanId], references: [id])

  @@unique([creatorId, fanId])
  @@index([creatorId])
  @@index([fanId])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  body           String?        // texto; null se for mídia
  mediaUrl       String?        // mensagem com mídia
  mediaType      MediaType?
  status         MessageStatus  @default(SENT)
  pricePaid      Int?           // centavos pagos para enviar (se conversa paga)
  isAutoReply    Boolean        @default(false)  // resposta automática configurada pelo criador
  createdAt      DateTime       @default(now())
  deletedAt      DateTime?      // soft delete

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─────────────────────────────────────────────────────────────
// NOTIFICAÇÕES
// ─────────────────────────────────────────────────────────────

enum NotificationType {
  NEW_SUBSCRIBER
  NEW_MESSAGE
  NEW_PPV_PURCHASE
  NEW_TIP
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  WITHDRAWAL_SCHEDULED
  WITHDRAWAL_COMPLETED
  CONTENT_APPROVED
  CONTENT_REJECTED
  STORY_VIEW
  SYSTEM
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  emailEnabled    Boolean  @default(true)
  pushEnabled     Boolean  @default(true)
  // Tipos desabilitados individualmente (array de NotificationType)
  disabledTypes   String[] @default([])
  maxPerDay       Int      @default(5)
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  readAt    DateTime?
  sentEmail Boolean          @default(false)
  sentPush  Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// BLOCO 5 — RETENÇÃO E RECEITA AVANÇADA
// ─────────────────────────────────────────────────────────────

// Item 23 — Gorjetas
model Tip {
  id          String   @id @default(cuid())
  senderId    String                         // fã que enviou
  creatorId   String                         // criador que recebeu
  amount      Decimal  @db.Decimal(10, 2)    // valor bruto (R$)
  netAmount   Decimal  @db.Decimal(10, 2)    // após taxa da plataforma (80%)
  message     String?  @db.VarChar(280)      // mensagem pública opcional
  isPublic    Boolean  @default(true)        // exibir no leaderboard?
  mediaId     String?                        // gorjeta em post específico
  createdAt   DateTime @default(now())

  @@index([creatorId, createdAt])
  @@index([senderId])
}

// Item 24 — Itens digitais
enum DigitalItemType {
  PHOTO_PACK
  VIDEO_PACK
  CUSTOM_REQUEST   // conteúdo personalizado encomendado
  VOICE_MESSAGE
  OTHER
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_PROGRESS
  DELIVERED
  CANCELLED
  DISPUTED
}

model DigitalItem {
  id           String          @id @default(cuid())
  creatorId    String
  title        String          @db.VarChar(100)
  description  String?         @db.VarChar(1000)
  type         DigitalItemType
  price        Decimal         @db.Decimal(10, 2)
  deliveryDays Int             @default(3)    // prazo prometido em dias úteis
  isActive     Boolean         @default(true)
  sampleUrl    String?                        // preview público (sem conteúdo adulto)
  orders       DigitalOrder[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([creatorId, isActive])
}

model DigitalOrder {
  id            String        @id @default(cuid())
  buyerId       String
  itemId        String
  item          DigitalItem   @relation(fields: [itemId], references: [id])
  status        OrderStatus   @default(PENDING_PAYMENT)
  price         Decimal       @db.Decimal(10, 2)
  netAmount     Decimal       @db.Decimal(10, 2)
  buyerNote     String?       @db.VarChar(500)  // instruções do comprador
  deliveryUrl   String?                          // link de entrega (S3 pré-assinado)
  deliveredAt   DateTime?
  deadlineAt    DateTime?                        // prazo = createdAt + deliveryDays
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([buyerId])
  @@index([itemId])
}

// Item 26 — Slots limitados + promoções
model SubscriptionSlotConfig {
  id          String   @id @default(cuid())
  creatorId   String   @unique
  maxSlots    Int?                       // null = ilimitado
  promoPrice  Decimal? @db.Decimal(10,2) // preço promocional temporário
  promoEndsAt DateTime?                  // null = sem promoção ativa
  updatedAt   DateTime @updatedAt
}

// Item 28 — Streaks e badges
model UserStreak {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)     // dias consecutivos de acesso
  longestStreak Int      @default(0)
  lastActiveAt  DateTime @default(now())
  totalDays     Int      @default(0)
  updatedAt     DateTime @updatedAt
}

model StreakBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeType   String                      // "WEEK_1", "MONTH_1", "MONTH_3", etc.
  earnedAt    DateTime @default(now())
  discountPct Int      @default(0)        // % de desconto associado ao badge

  @@unique([userId, badgeType])
  @@index([userId])
}

// Item 29 — Programa de referência
model ReferralCode {
  id          String   @id @default(cuid())
  userId      String   @unique
  code        String   @unique            // ex: "MARIO2024"
  creditBRL   Decimal  @db.Decimal(10,2)  @default(15.00)  // crédito por indicação
  totalReferrals Int   @default(0)
  totalEarned Decimal  @db.Decimal(10,2)  @default(0)
  createdAt   DateTime @default(now())
  referrals   Referral[]
}

model Referral {
  id           String       @id @default(cuid())
  referralCode String
  code         ReferralCode @relation(fields: [referralCode], references: [code])
  referrerId   String                            // quem indicou
  referredId   String       @unique              // quem foi indicado (1 por pessoa)
  creditGranted Boolean     @default(false)      // crédito já aplicado?
  creditAmount  Decimal     @db.Decimal(10,2)    @default(0)
  createdAt    DateTime     @default(now())

  @@index([referrerId])
  @@index([referralCode])
}

// ─────────────────────────────────────────────────────────────
// BLOCO 6 — LIVES E INTERATIVIDADE
// ─────────────────────────────────────────────────────────────

// Item 30 — Lives
model LiveSession {
  id              String      @id @default(cuid())
  creatorId       String
  title           String      @db.VarChar(200)
  description     String?     @db.VarChar(1000)
  status          LiveStatus  @default(SCHEDULED)
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?

  // LiveKit
  livekitRoomName String?     @unique
  livekitToken    String?     // token do host (rotacionado a cada live)

  // Acesso
  requiresSubscription Boolean @default(true)
  maxViewers          Int?                       // null = ilimitado
  viewerCount         Int     @default(0)
  peakViewers         Int     @default(0)

  // Gravação — apenas com consentimento explícito do criador
  recordingEnabled    Boolean @default(false)
  recordingConsentAt  DateTime?
  recordingUrl        String?

  creator     User        @relation("CreatorLives", fields: [creatorId], references: [id])
  superChats  SuperChat[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([creatorId, status])
  @@index([scheduledAt])
}

// Item 31 — Super Chat (pay-to-interact)
model SuperChat {
  id          String      @id @default(cuid())
  liveId      String
  live        LiveSession @relation(fields: [liveId], references: [id])
  senderId    String
  amount      Int                               // centavos
  netAmount   Int                               // após taxa 20%
  message     String      @db.VarChar(200)
  color       String      @default("#9333ea")  // cor baseada no valor
  pinnedUntil DateTime?                         // destaque temporário no chat
  createdAt   DateTime    @default(now())

  @@index([liveId, createdAt])
}

// Item 32 — Leilões
model Auction {
  id             String        @id @default(cuid())
  creatorId      String
  title          String        @db.VarChar(200)
  description    String?       @db.VarChar(2000)
  mediaId        String?       // conteúdo a ser entregue ao vencedor
  startingBid    Int           // centavos
  currentBid     Int           @default(0)
  winnerId       String?
  status         AuctionStatus @default(DRAFT)
  endsAt         DateTime
  deliveredAt    DateTime?
  deliveryUrl    String?       // URL pré-assinada entregue ao vencedor

  bids           AuctionBid[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([creatorId, status])
  @@index([endsAt])
}

model AuctionBid {
  id        String   @id @default(cuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])
  bidderId  String
  amount    Int      // centavos
  createdAt DateTime @default(now())

  @@index([auctionId, amount])
  @@index([bidderId])
}

// Item 33 — Toys IoT
model ToySession {
  id          String           @id @default(cuid())
  creatorId   String
  liveId      String?          // opcional: vinculada a uma live
  status      ToySessionStatus @default(ACTIVE)

  // Consentimento explícito por sessão (nunca global)
  consentAt   DateTime         @default(now())
  consentText String           // texto exibido ao criador antes de ativar

  // Configuração de controle
  minIntensity  Int            @default(0)   // 0–100
  maxIntensity  Int            @default(50)  // cap máximo que fãs podem atingir
  pricePerMin   Int            // centavos por minuto de controle
  minPayBRL     Int            @default(500) // R$ 5,00 mínimo por ativação

  controls    ToyControl[]
  endedAt     DateTime?
  createdAt   DateTime         @default(now())

  @@index([creatorId, status])
}

model ToyControl {
  id          String     @id @default(cuid())
  sessionId   String
  session     ToySession @relation(fields: [sessionId], references: [id])
  userId      String     // fã que pagou
  durationSec Int        // segundos comprados
  intensity   Int        // 0–100 (respeitado o maxIntensity)
  amountPaid  Int        // centavos
  netAmount   Int        // após taxa 20%
  startedAt   DateTime   @default(now())
  endsAt      DateTime

  @@index([sessionId, endsAt])
}

// ─────────────────────────────────────────────────────────────
// BLOCO 7 — AFILIADOS E DISTRIBUIÇÃO
// ─────────────────────────────────────────────────────────────

// Item 34 — Programa de afiliados 2 níveis
enum AffiliateStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model Affiliate {
  id             String          @id @default(cuid())
  userId         String          @unique
  status         AffiliateStatus @default(ACTIVE)
  referredByCode String?         // código do afiliado nível 1 que o recrutou (para nível 2)

  // Comissões
  l1Rate         Decimal         @db.Decimal(5,4) @default(0.2000)  // 20% nível 1
  l2Rate         Decimal         @db.Decimal(5,4) @default(0.0500)  // 5%  nível 2
  capMonthlyBRL  Decimal         @db.Decimal(10,2) @default(5000)   // cap R$5k/mês

  // Saldo acumulado
  pendingBRL     Decimal         @db.Decimal(10,2) @default(0)
  paidBRL        Decimal         @db.Decimal(10,2) @default(0)
  totalEarnedBRL Decimal         @db.Decimal(10,2) @default(0)

  commissions    AffiliateCommission[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
}

model AffiliateCommission {
  id             String   @id @default(cuid())
  affiliateId    String
  affiliate      Affiliate @relation(fields: [affiliateId], references: [id])
  sourceUserId   String   // usuário cuja transação gerou a comissão
  transactionId  String?  // Transaction que originou
  level          Int      // 1 ou 2
  grossBRL       Decimal  @db.Decimal(10,2)  // valor da transação original
  commissionBRL  Decimal  @db.Decimal(10,2)  // valor da comissão
  paid           Boolean  @default(false)
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([affiliateId, paid])
  @@index([sourceUserId])
}

// Item 35 — Social Scheduler
enum SocialPlatform {
  INSTAGRAM
  TWITTER_X
  TIKTOK
}

enum ScheduledPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

model ScheduledPost {
  id          String              @id @default(cuid())
  creatorId   String
  platform    SocialPlatform
  caption     String              @db.VarChar(2200)
  mediaUrl    String?             // teaser (sem conteúdo adulto explícito)
  scheduledAt DateTime
  publishedAt DateTime?
  status      ScheduledPostStatus @default(DRAFT)
  externalId  String?             // ID do post na rede social
  errorMsg    String?
  clicks      Int                 @default(0)
  conversions Int                 @default(0)   // novos assinantes via link rastreado
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([creatorId, scheduledAt])
  @@index([status, scheduledAt])
}

// Item 36 — Tier Acesso Verificado
enum VerifiedTierStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
}

model VerifiedTierAccess {
  id           String             @id @default(cuid())
  userId       String             @unique
  status       VerifiedTierStatus @default(INACTIVE)
  grantedAt    DateTime?
  revokedAt    DateTime?
  // Revogar automaticamente se KYC for cancelado
  kycVerifId   String?

  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────────
// BLOCO 8 — IA E DIFERENCIAÇÃO
// ─────────────────────────────────────────────────────────────

// Item 37 — AI Persona
model AiPersona {
  id           String   @id @default(cuid())
  creatorId    String   @unique
  displayName  String   @db.VarChar(60)    // "IA da Fulana"
  voiceTone    String   @db.VarChar(500)   // instruções de tom
  systemPrompt String   @db.VarChar(4000)  // prompt base para o modelo
  enabled      Boolean  @default(false)
  // FAQ enlatado: array de {q, a}
  faqEntries   Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AiPersonaMessage {
  id         String   @id @default(cuid())
  personaId  String
  userId     String   // fã que recebeu a resposta
  userMsg    String   @db.VarChar(2000)
  aiReply    String   @db.VarChar(4000)
  modelUsed  String   // ex: "claude-haiku-4-5"
  createdAt  DateTime @default(now())

  @@index([personaId, createdAt])
}

// Item 39 — Collab matches
enum CollabStatus {
  PENDING    // sugestão automática
  INVITED    // um dos criadores enviou convite
  ACCEPTED   // ambos aceitaram
  REJECTED
  CANCELLED
}

model CollabMatch {
  id          String       @id @default(cuid())
  creatorAId  String
  creatorBId  String
  score       Float        // score de compatibilidade 0–1
  status      CollabStatus @default(PENDING)
  initiatedBy String?      // quem enviou convite (null = sugestão automática)
  acceptedAt  DateTime?
  contractId  String?      // ref para CollabContract após aceite

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([creatorAId, creatorBId])
  @@index([creatorAId, status])
  @@index([creatorBId, status])
}

// Item 40 — Contratos IA
enum ContractStatus {
  DRAFT
  PENDING_SIGNATURES
  SIGNED
  EXPIRED
  CANCELLED
}

model CollabContract {
  id              String         @id @default(cuid())
  matchId         String?
  creatorAId      String
  creatorBId      String
  status          ContractStatus @default(DRAFT)

  // Termos gerados pela IA
  terms           Json           // { revenueSplit, exclusivity, durationDays, ... }
  fullText        String         @db.Text   // texto completo do contrato
  summary         String         @db.VarChar(2000) // resumo em linguagem simples

  // Assinaturas via token SMS
  tokenA          String?        // token OTP enviado ao criadorA
  tokenAExpiresAt DateTime?
  signedByAAt     DateTime?

  tokenB          String?
  tokenBExpiresAt DateTime?
  signedByBAt     DateTime?

  // Armazenamento imutável no S3
  s3Key           String?        // após assinatura dupla
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([creatorAId])
  @@index([creatorBId])
}

// Item 41 — Torneios
enum TournamentMetric {
  NEW_SUBSCRIBERS
  REVENUE
  CONTENT_VIEWS
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  ENDED
  PAID
}

model Tournament {
  id           String            @id @default(cuid())
  name         String            @db.VarChar(200)
  description  String            @db.VarChar(2000)
  metric       TournamentMetric
  status       TournamentStatus  @default(UPCOMING)
  startsAt     DateTime
  endsAt       DateTime
  prizePoolBRL Decimal           @db.Decimal(10,2)
  rulesJson    Json              // regulamento público e auditável
  // Distribuição: [{ rank: 1, pct: 50 }, { rank: 2, pct: 30 }, ...]
  prizeDistrib Json
  entries      TournamentEntry[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, endsAt])
}

model TournamentEntry {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  creatorId    String
  score        Decimal    @db.Decimal(14,2) @default(0)
  rank         Int?
  prizeBRL     Decimal    @db.Decimal(10,2) @default(0)
  paid         Boolean    @default(false)
  updatedAt    DateTime   @updatedAt

  @@unique([tournamentId, creatorId])
  @@index([tournamentId, score])
}

// ─────────────────────────────────────────────────────────────
// BLOCO 9 — EXPANSÃO MOBILE E CRYPTO
// ─────────────────────────────────────────────────────────────

// Item 43 — Pagamentos cripto

enum CryptoTxStatus {
  PENDING               // aguardando pagamento
  AWAITING_CONFIRMATION // pagamento detectado, aguardando confirmações
  CONFIRMED             // confirmado on-chain
  EXPIRED               // janela de pagamento expirou
  FAILED
}

model CryptoTransaction {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])

  currency      String         @db.VarChar(10)  // BTC | USDC | USDT
  amountCrypto  Decimal        @db.Decimal(20,8)
  amountBRL     Decimal        @db.Decimal(10,2)
  exchangeRate  Decimal        @db.Decimal(20,8)

  status        CryptoTxStatus @default(PENDING)
  providerRef   String?        // charge ID do Coinbase Commerce / BTCPay
  walletAddress String         @db.VarChar(200)

  // KYC tier: LOW = só email+wallet (<R$2k/mês); HIGH = KYC completo
  kycTier       String         @default("LOW")  // LOW | HIGH

  confirmedAt   DateTime?
  expiresAt     DateTime

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@index([providerRef])
  @@index([status, expiresAt])
}

// Item 44 — Matches por região

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  city      String   @db.VarChar(100)
  state     String   @db.VarChar(2)    // sigla do estado (ex: SP, RJ)
  country   String   @default("BR")   @db.VarChar(2)

  optedInAt DateTime @default(now())
  expiresAt DateTime  // 30 dias — purge automático @Cron

  @@index([state])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// BLOCO 10 — INOVAÇÃO
// ─────────────────────────────────────────────────────────────

// Item 45 — AI Avatar

enum AvatarStatus {
  PENDING_UPLOAD    // aguardando fotos/áudio
  QUEUED            // na fila de treinamento
  TRAINING          // treinando modelo
  READY             // pronto para gerar
  FAILED
}

model AiAvatar {
  id          String       @id @default(cuid())
  creatorId   String       @unique
  creator     User         @relation(fields: [creatorId], references: [id])

  status      AvatarStatus @default(PENDING_UPLOAD)

  // Referências S3 — bucket privado (nunca público)
  photoKeys   Json         @default("[]")  // string[] — até 200 fotos
  audioKey    String?                      // áudio de referência (voz)

  // Consentimento documentado — obrigatório antes de treinar
  consentText String       @db.Text
  consentedAt DateTime?

  // Resultado do treinamento
  modelRef    String?      // ID do modelo no serviço de treinamento (Replicate/RunPod)
  errorMsg    String?

  // Configurações de uso
  allowFanGeneration Boolean @default(false) // fãs podem gerar variações?
  maxGenPerDay       Int     @default(10)    // limite diário de gerações

  generations AiAvatarGeneration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

model AiAvatarGeneration {
  id         String           @id @default(cuid())
  avatarId   String
  avatar     AiAvatar         @relation(fields: [avatarId], references: [id])
  requestedBy String          // userId (criador ou fã autorizado)

  prompt     String           @db.VarChar(500)
  resultKey  String?          // S3 key da imagem gerada
  status     GenerationStatus @default(QUEUED)
  errorMsg   String?

  // Moderação — output da IA também passa por CSAM check
  moderationPassed Boolean?
  moderatedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([avatarId, requestedBy])
  @@index([status])
}

// Item 46 — IA para geração de conteúdo

enum ContentGenStatus {
  QUEUED
  PROCESSING
  PENDING_MODERATION
  APPROVED
  REJECTED
}

model ContentGenJob {
  id         String          @id @default(cuid())
  creatorId  String
  creator    User            @relation(fields: [creatorId], references: [id])

  prompt     String          @db.VarChar(1000)
  jobType    String          @db.VarChar(50)  // "background" | "effect" | "scene"
  status     ContentGenStatus @default(QUEUED)

  inputKey   String?         // S3 key do conteúdo base (opcional)
  outputKey  String?         // S3 key do resultado
  errorMsg   String?

  // Salvaguardas
  moderationPassed Boolean?
  moderatedAt      DateTime?
  rejectionReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId, status])
}

// Item 47 — Edição colaborativa com fãs

enum EditSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model EditSuggestion {
  id        String               @id @default(cuid())
  mediaId   String
  media     Media                @relation(fields: [mediaId], references: [id])
  fanId     String
  fan       User                 @relation("FanEditSuggestions", fields: [fanId], references: [id])

  type      String               @db.VarChar(50)  // "cut" | "caption" | "soundtrack"
  payload   Json                 // dados específicos do tipo (ex: { start: 10, end: 25 })
  note      String?              @db.VarChar(500) // justificativa do fã

  status    EditSuggestionStatus @default(PENDING)

  // Monetização — configurada pelo criador ao aceitar
  revenueSharePct Int?           // % da receita do conteúdo editado para o fã
  acceptedAt      DateTime?
  rejectedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([mediaId, status])
  @@index([fanId])
}

// Item 48 — Conteúdo VR/AR

enum VrFormat {
  VR180
  VR360
  AR_MARKER  // marcador AR (futuro)
}

model VrContent {
  id         String   @id @default(cuid())
  mediaId    String   @unique
  media      Media    @relation(fields: [mediaId], references: [id])

  format     VrFormat
  resolution String   @db.VarChar(20) // "4K" | "8K" | "2K"

  // S3 keys por qualidade (upgrade in-app desbloqueia resolução maior)
  key2K      String?
  key4K      String?
  key8K      String?

  // WebXR metadata
  stereoMode  String  @default("top-bottom")  // "top-bottom" | "side-by-side"
  fovDegrees  Int     @default(180)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// RASTREABILIDADE DE ACESSO A CONTEÚDO
// ─────────────────────────────────────────────────────────────

model MediaAccessLog {
  id          String   @id @default(cuid())
  mediaId     String
  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  userId      String?            // null = anônimo (conteúdo público)
  sessionId   String?            // ref Session.id para vincular ao dispositivo/IP

  // Dados da sessão capturados no momento do acesso
  ipAddress   String?
  userAgent   String?
  country     String?  @db.VarChar(2)

  // Detalhes de consumo
  accessType  String   @default("VIEW")  // VIEW | DOWNLOAD | STREAM
  durationSec Int?                        // tempo assistido (vídeos)
  completedAt DateTime?                   // null = não terminou

  createdAt   DateTime @default(now())

  @@index([mediaId, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([ipAddress])
}

// ─────────────────────────────────────────────────────────────
// DUPLA CUSTÓDIA — MODERAÇÃO COM 2 REVISORES INDEPENDENTES
// ─────────────────────────────────────────────────────────────

enum CustodyDecision {
  APPROVE
  REJECT
  ESCALATE
}

model ContentCustodyReview {
  id          String          @id @default(cuid())
  mediaId     String
  media       Media           @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  // Primeiro revisor
  reviewer1Id String?
  decision1   CustodyDecision?
  reason1     String?
  reviewedAt1 DateTime?

  // Segundo revisor (independente — não vê decisão do primeiro)
  reviewer2Id String?
  decision2   CustodyDecision?
  reason2     String?
  reviewedAt2 DateTime?

  // Decisão final consolidada
  finalDecision CustodyDecision?
  resolvedAt    DateTime?
  resolvedBy    String?          // "SYSTEM" ou moderatorId (em caso de conflito)
  conflictNote  String?          // preenchido quando há divergência

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mediaId])
  @@index([reviewer1Id])
  @@index([reviewer2Id])
  @@index([finalDecision])
}
